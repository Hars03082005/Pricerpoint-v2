# ── Large training datasets (GitHub 100 MB file limit) ────────────────────────
# Raw and cleaned CSVs are large; keep only brand_stats.csv (small reference file)
ml_training/data/cars.csv
ml_training/data/cleaned.csv
ml_training/data/*.zip
# Keep brand_stats.csv (tiny) and any .gitkeep sentinels
!ml_training/data/brand_stats.csv
!ml_training/data/.gitkeep

# ── Large model artifacts (GitHub 100 MB limit) ───────────────────────────────
# Segment ensemble pickles — all 4 brand classes (~43–76 MB each)
model_artifacts/ensemble_*.pkl
# Global CatBoost model (~0.8 MB — within limit but binary, retrain-able)
model_artifacts/vehicle_price_catboost.cbm
# Global XGBoost model (~2.2 MB)
model_artifacts/vehicle_price_xgboost.json
# Global LightGBM model (~2.5 MB — kept; remove if repo size is a concern)
# model_artifacts/vehicle_price_lightgbm.txt

# training_report.json is an exact duplicate of model_metadata.json — skip it
model_artifacts/training_report.json

# Small files kept for documentation & reproducibility:
#   model_artifacts/model_metadata.json        (~110 KB)
#   model_artifacts/cleaned_training_sample.csv (~56 KB)

# ── Mobile (Flutter) ──────────────────────────────────────────────────────────
mobile/.dart_tool/
mobile/.idea/
mobile/.flutter-plugins-dependencies
mobile/.metadata
mobile/build/
mobile/assets/flutter_assets/
# Keep mobile/assets/web/ (the bundled React app for WebView)

